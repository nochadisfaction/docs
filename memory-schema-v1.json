{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pixelated.ai/schemas/memory/v1.0.0",
  "title": "UnifiedMemory",
  "description": "Canonical memory object schema for the Pixelated Empathy platform. All services validate at API boundaries against this schema. Sprint 1 / ADHD-318.",
  "type": "object",
  "required": [
    "id",
    "tenantId",
    "userId",
    "bankId",
    "content",
    "scope",
    "retention",
    "category",
    "tags",
    "version",
    "schemaVersion",
    "sourceService",
    "importance",
    "decayRate",
    "strengthTrend",
    "activationCount",
    "retrievalCount",
    "isGhost",
    "synthesizedFrom",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 — globally unique"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Tenant identifier for hard multi-tenant isolation"
    },
    "userId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "User identifier"
    },
    "bankId": {
      "type": "string",
      "minLength": 1,
      "description": "Memory bank logical grouping"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100000,
      "description": "Primary memory content"
    },
    "scope": {
      "type": "string",
      "enum": ["session", "arc", "trait", "fact"],
      "description": "Lifecycle boundary of the memory"
    },
    "retention": {
      "type": "string",
      "enum": ["ephemeral", "short_term", "long_term", "permanent"],
      "description": "Eviction policy"
    },
    "category": {
      "type": "string",
      "description": "Category label (fact, crisis, conversation, preference, general)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form tags"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing version counter"
    },
    "schemaVersion": {
      "type": "string",
      "description": "Semver of the UnifiedMemory schema that wrote this record"
    },
    "sourceService": {
      "type": "string",
      "enum": ["foresight", "ai-services", "astro-frontend", "unknown"],
      "description": "Which service originally created this memory"
    },
    "importance": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Current importance score"
    },
    "decayRate": {
      "type": "number",
      "minimum": 0.0,
      "description": "Fraction of importance lost per hour"
    },
    "strengthTrend": {
      "type": "string",
      "enum": ["stable", "strengthening", "weakening", "stale"],
      "description": "Current strength trend from temporal scheduler"
    },
    "activationCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of times this memory was activated"
    },
    "retrievalCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of times this memory appeared in search results"
    },
    "isGhost": {
      "type": "boolean",
      "description": "True if this is a compressed Ghost Node"
    },
    "gist": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "10-word gist summary (Ghost Nodes and synthesized memories)"
    },
    "synthesizedFrom": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "description": "Source memory IDs this was synthesized from"
    },
    "vectorId": {
      "type": ["string", "null"],
      "description": "Reference ID in vector store"
    },
    "emotionalContext": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "valence",
            "arousal",
            "dominance",
            "primaryEmotion",
            "intensity"
          ],
          "additionalProperties": false,
          "properties": {
            "valence": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
            "arousal": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "dominance": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "primaryEmotion": { "type": "string" },
            "intensity": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        { "type": "null" }
      ]
    },
    "empathyMetrics": {
      "oneOf": [
        {
          "type": "object",
          "required": ["reciprocity", "validationAccuracy", "resistanceLevel"],
          "additionalProperties": false,
          "properties": {
            "reciprocity": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "validationAccuracy": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "resistanceLevel": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        },
        { "type": "null" }
      ]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": ["string", "null"], "format": "date-time" },
    "accessedAt": { "type": ["string", "null"], "format": "date-time" },
    "lastRetrievedAt": { "type": ["string", "null"], "format": "date-time" }
  }
}
